# OpenSearch Configuration
# Generated by Chef - Local modifications will be overwritten

cluster.name: <%= @cluster_name %>
node.name: <%= @node_name %>

# Paths
path.data: <%= @path_data %>
path.logs: <%= @path_logs %>

# Network
network.host: <%= @listen_host %>
http.port: <%= @listen_port %>

# Discovery (single node for AxonOps)
discovery.type: single-node

<% if @security_plugin_enabled -%>
# Security plugin is enabled — configure plugins.security.* (TLS certs,
# internal users, roles) yourself; this cookbook doesn't generate certs or
# an admin password automatically. See docs/OPENSEARCH.md.
<% else -%>
# Security plugin disabled — no auth, no TLS. Matches this cookbook's
# previous no-auth Elasticsearch tarball install. Set
# node['axonops']['server']['elastic']['security_plugin_enabled'] = true
# and configure plugins.security.* yourself for a production-hardened setup.
plugins.security.disabled: true
<% end -%>

# Additional settings
#
# Not setting bootstrap.memory_lock here — enabling it without a
# corresponding LimitMEMLOCK override needs OpenSearch's bootstrap check to
# fail ("memory locking requested ... but memory is not locked") on
# anything but pure loopback dev-mode. This recipe deliberately doesn't
# reinvent the package's own systemd unit/limits (see recipes/opensearch.rb),
# so leave this off rather than half-wire memory locking.
indices.query.bool.max_clause_count: 8192
