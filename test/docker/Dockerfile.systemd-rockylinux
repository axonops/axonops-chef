# Base image for kitchen-docker Rocky Linux platforms that actually boots
# systemd as PID 1. See Dockerfile.systemd-ubuntu for why this is needed —
# same fix, RHEL-family package manager.
FROM rockylinux:9

RUN dnf install -y systemd \
    && dnf clean all

# See Dockerfile.systemd-ubuntu — kitchen's verify step needs CHEF_LICENSE
# accepted inside the container itself, not just on the CI runner.
RUN echo 'CHEF_LICENSE=accept-no-persist' >> /etc/environment

STOPSIGNAL SIGRTMIN+3
