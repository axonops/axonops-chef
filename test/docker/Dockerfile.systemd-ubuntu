# Base image for kitchen-docker Ubuntu platforms that actually boots systemd
# as PID 1. Stock ubuntu:22.04 has no systemd at all — kitchen-docker runs
# `sshd -D` as PID 1 by default, which never gives package postinst scripts
# a real init system/dbus to talk to. AxonOps packages call systemctl in
# their postinst, and fail hard without one. kitchen-docker's own generated
# Dockerfile (sudo/openssh-server/user setup) still layers on top of this
# unmodified — only the base changes, and kitchen.yml overrides run_command
# to boot systemd instead of sshd directly.
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
    && apt-get install -y systemd systemd-sysv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# kitchen's verify step installs Chef Workstation fresh inside the
# container, which needs CHEF_LICENSE accepted there too — CHEF_LICENSE set
# on the CI runner only covers commands the runner itself executes.
# kitchen-docker's transport uses native `docker exec` (confirmed directly
# in its source, lib/kitchen/docker/container/linux.rb), not SSH — so this
# has to be a real container-level ENV, which docker exec inherits from
# PID 1. /etc/environment (a PAM/login-shell mechanism) looked right in an
# SSH test but isn't what kitchen-docker actually uses to run commands.
ENV CHEF_LICENSE=accept-no-persist

STOPSIGNAL SIGRTMIN+3
